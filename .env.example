# ── Trading Mode ─────────────────────────────────
# Change ONLY this value to switch modes: paper | live
TRADE_MODE=paper

# Extended hours equity trading (4 AM - 8 PM ET)
EXTENDED_HOURS_EQUITY_TRADING=true

# Trade Ideas equity trading
USE_TI_PRIMARY_EQUITY_TRADING=true
TI_EQUITY_BASE_CONFIDENCE=0.85

# Equity and Options ensemble features
USE_EQUITY_ENSEMBLE=true
USE_OPTIONS_ENSEMBLE=true

OPTIONS_ENABLED=true
OPTIONS_ALLOCATION_PCT=45.0
OPTIONS_TRAIL_ACTIVATE_PCT=20.0
OPTIONS_TRAIL_DRAWDOWN_PCT=15.0

# ── Testing / Dev flags ───────────────────────────────────────────
# Set FORCE_SCAN=true to bypass market-hours gate (run scans 24/7)
FORCE_SCAN=false
# Set FORCE_EQUITY=true to run equity/options on weekends (for testing)
FORCE_EQUITY=false

# ════════════════════════════════════════════════════════════════════
# REQUIRED CREDENTIALS — MUST SET BEFORE TRADING
# ════════════════════════════════════════════════════════════════════

# ── Alpaca Paper credentials (for paper trading) ───────────────────
PAPER_ALPACA_API_KEY=your_paper_alpaca_api_key_here
PAPER_ALPACA_API_SECRET=your_paper_alpaca_api_secret_here

# ── Alpaca Live credentials (for live trading) ────────────────────
LIVE_ALPACA_API_KEY=your_live_alpaca_api_key_here
LIVE_ALPACA_API_SECRET=your_live_alpaca_api_secret_here

# ── Schwab OAuth credentials (PRIMARY market data source) ──────────
# Schwab: Candles (bars) + Options chains
SCHWAB_CLIENT_ID=your_schwab_client_id_here
SCHWAB_CLIENT_SECRET=your_schwab_client_secret_here
# SCHWAB_ACCOUNT_NUMBER=  # Add if using Schwab for trading (optional)
# SCHWAB_USE_SANDBOX=false  # Set true for Schwab paper trading

# ════════════════════════════════════════════════════════════════════
# OPTIONAL CREDENTIALS — Only if using specific features
# ════════════════════════════════════════════════════════════════════

# Finnhub API (optional — used for RS metric calculation)
FINNHUB_API_KEY=your_finnhub_api_key_here

# Broker selection (default: alpaca for execution)
STOCKS_BROKER=alpaca

# Polygon.io (optional — alternative data source)
POLYGON_API_KEY=your_polygon_api_key_here

# Email notifications
USE_EMAIL_NOTIFICATIONS=true
EMAIL_TO_ADDRESSES=your_email@example.com
EMAIL_FROM_ADDRESS=your_email@example.com
EMAIL_SMTP_USER=your_email@example.com
EMAIL_SMTP_PASSWORD=your_smtp_password_here

# Trade Ideas discovery
USE_TRADEIDEAS_DISCOVERY=true